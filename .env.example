NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Admin 後台簡易保護（Step 1）
ADMIN_SECRET=change-me-to-a-long-random-string

# 人工收款（MVP-B v1，NT$99/月）
MANUAL_PAYMENT_BANK_CODE=822
MANUAL_PAYMENT_BANK_NAME=你的銀行名稱
MANUAL_PAYMENT_ACCOUNT=你的帳號
MANUAL_PAYMENT_ACCOUNT_NAME=你的戶名
MANUAL_PAYMENT_NOTE=Logic Gym 付費會員
MANUAL_PAYMENT_FORM_URL=https://forms.google.com/你的表單
MANUAL_PAYMENT_CONTACT=your@email.com

